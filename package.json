{
  "name": "mesh",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev -H localhost --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=test-results/junit.xml --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list --reporter=junit",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky",
    "cap:sync": "cap sync android",
    "cap:run": "cap run android",
    "cap:open": "cap open android",
    "cap:build": "cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
